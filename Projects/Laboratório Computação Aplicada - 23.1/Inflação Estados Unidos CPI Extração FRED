ow='inner', on='date')\n","      \n","  #transformo em float no astype(float)\n","  return macro_data"]},{"cell_type":"markdown","source":["Extraindo a Inflação Americana"],"metadata":{"id":"3c-HdhGP1UBu"}},{"cell_type":"code","source":["\n","series_names = ['cpi']\n","series_ids = ['CPIAUCSL']\n","\n","US_data = compile_FRED(series_names, series_ids, obs_start = '2016-01-01', obs_end = '2021-07-01')\n","\n","US_data['cpi_inflation_rate'] = 100*US_data['cpi'].pct_change()\n","# inflação per capita \n","\n","US_data = US_data.dropna()\n","#Tira os valores em A, tira as linhas associadas a observações\n","\n","US_data.head()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":225},"id":"s-SkpoKG0b5L","executionInfo":{"status":"ok","timestamp":1667850231578,"user_tz":180,"elapsed":1130,"user":{"displayName":"Alex Temporal","userId":"14320214844571273232"}},"outputId":"afe64b48-1bbc-4f1f-9f68-f9d379f6ef78"},"execution_count":26,"outputs":[{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.7/dist-packages/ipykernel_launcher.py:22: FutureWarning: pandas.io.json.json_normalize is deprecated, use pandas.json_normalize instead\n"]},{"output_type":"execute_result","data":{"text/plain":["         date      cpi  cpi_inflation_rate\n","1  2016-02-01  237.336           -0.132968\n","2  2016-03-01  238.080            0.313480\n","3  2016-04-01  238.992            0.383065\n","4  2016-05-01  239.557            0.236410\n","5  2016-06-01  240.222            0.277596"],"text/html":["\n","  <div id=\"df-56f663ba-a498-4f17-be14-b571c0ba77b4\">\n","    <div class=\"colab-df-container\">\n","      <div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr s